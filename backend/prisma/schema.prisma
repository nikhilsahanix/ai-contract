generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Org ─────────────────────────────────────────────────────────────────────

model Org {
  id               String       @id @default(uuid())
  name             String
  slug             String       @unique
  plan             Plan         @default(SOLO)
  stripeCustomerId String?      @unique
  stripeSubId      String?      @unique
  analysisCount    Int          @default(0)   // incremented ONLY on successful completion
  analysisLimit    Int          @default(25)  // SOLO=25, FIRM=100, MAX=250, ENTERPRISE=99999
  dataRegion       DataRegion   @default(US)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  users            User[]
  contracts        Contract[]
  apiKeys          ApiKey[]
  webhooks         OrgWebhook[]
  auditLogs        AuditLog[]

  @@map("orgs")
}

// ─── User ─────────────────────────────────────────────────────────────────────

model User {
  id               String         @id @default(uuid())
  orgId            String
  email            String         @unique
  passwordHash     String
  role             UserRole       @default(ATTORNEY)
  emailVerified    Boolean        @default(false)
  twoFactorEnabled Boolean        @default(false)
  twoFactorSecret  String?
  lastLoginAt      DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  org              Org            @relation(fields: [orgId], references: [id], onDelete: Cascade)
  refreshTokens    RefreshToken[]

  @@map("users")
}

// ─── RefreshToken ─────────────────────────────────────────────────────────────

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

// ─── ApiKey ───────────────────────────────────────────────────────────────────

model ApiKey {
  id         String    @id @default(uuid())
  orgId      String
  name       String
  keyHash    String    @unique
  keyPrefix  String
  lastUsedAt DateTime?
  expiresAt  DateTime?
  rateLimit  Int       @default(100)
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  org        Org       @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("api_keys")
}

// ─── Contract ─────────────────────────────────────────────────────────────────

model Contract {
  id               String         @id @default(uuid())
  orgId            String
  uploadedByUserId String?
  originalName     String
  contractType     ContractType   @default(UNKNOWN)
  jurisdiction     String?
  storageKey       String         @unique
  fileSizeBytes    Int
  pageCount        Int?
  status           ContractStatus @default(PENDING)
  expiresAt        DateTime?
  deletedAt        DateTime?      // soft delete
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  org              Org            @relation(fields: [orgId], references: [id], onDelete: Cascade)
  analyses         Analysis[]

  @@index([orgId, status])
  @@index([orgId, createdAt])
  @@map("contracts")
}

// ─── Analysis ─────────────────────────────────────────────────────────────────

model Analysis {
  id               String         @id @default(uuid())
  contractId       String
  jobId            String         @unique  // BullMQ job ID
  status           AnalysisStatus @default(QUEUED)
  riskScore        Float?         // 0.0–10.0
  riskLevel        RiskLevel?
  // Full structured output stored here:
  // { flags, missingClauses, positives, negotiationPriority,
  //   jurisdictionNotes, executiveTakeaway, favoursParty,
  //   contractType, extractionMeta }
  flagsJson        Json?
  summaryText      String?        // executiveSummary plain text
  redlineKey       String?        // S3 key for redline PDF
  aiModel          String?
  promptTokens     Int?
  completionTokens Int?
  processingMs     Int?
  errorMessage     String?
  retryCount       Int            @default(0)
  // counted = true means this analysis was counted against org quota
  // prevents double-counting on retries
  counted          Boolean        @default(false)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  contract         Contract       @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId, status])
  @@map("analyses")
}

// ─── OrgWebhook ───────────────────────────────────────────────────────────────

model OrgWebhook {
  id        String   @id @default(uuid())
  orgId     String
  url       String
  secret    String   // HMAC-SHA256 signing secret
  events    String[] // e.g. ["analysis.completed", "analysis.failed"]
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  org       Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("org_webhooks")
}

// ─── AuditLog ─────────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(uuid())
  orgId      String
  userId     String?
  apiKeyId   String?
  action     String   // e.g. "contract.uploaded", "analysis.completed", "user.login"
  resourceId String?
  ipAddress  String?
  userAgent  String?
  metadata   Json?
  createdAt  DateTime @default(now())
  org        Org      @relation(fields: [orgId], references: [id])

  @@index([orgId, createdAt])
  @@map("audit_logs")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Plan {
  SOLO         // 25 analyses/month
  FIRM         // 100 analyses/month
  MAX          // 250 analyses/month
  ENTERPRISE   // 99999 (unlimited)
}

enum UserRole {
  ADMIN
  ATTORNEY
  VIEWER
}

enum ContractType {
  NDA
  SERVICE_AGREEMENT
  EMPLOYMENT
  SOFTWARE_LICENSE
  REAL_ESTATE
  PARTNERSHIP
  UNKNOWN
}

enum ContractStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum AnalysisStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum DataRegion {
  US
  EU
}